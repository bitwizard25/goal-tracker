{
  "name": "goal-tracker-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Advanced goal tracking app with psychological-based habit formation and energy-emotion tracking",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:frontend": "pnpm --filter @goal-tracker/frontend dev",
    "dev:backend": "pnpm --filter @goal-tracker/backend dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter @goal-tracker/frontend build",
    "build:backend": "pnpm --filter @goal-tracker/backend build",
    "start": "node apps/backend/dist/index.js",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "vite": "^5.4.11"
    }
  }
}